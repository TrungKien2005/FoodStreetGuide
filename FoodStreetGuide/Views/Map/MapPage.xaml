<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="doanC_.Views.MapPage"
             x:Name="RootPage">

    <Grid RowDefinitions="*,Auto">

        <!-- BẢN ĐỒ -->
        <AbsoluteLayout Grid.Row="0">

            <!-- GOOGLE MAP -->
            <maps:Map x:Name="map"
                      IsShowingUser="True"
                      AbsoluteLayout.LayoutBounds="0,0,1,1"
                      AbsoluteLayout.LayoutFlags="All"/>

            <!-- Thanh tìm kiếm -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    Padding="10"
                    Margin="20,20,20,0"
                    AbsoluteLayout.LayoutBounds="0.5,0.08,0.9,60"
                    AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional">

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <Label Text="🔍"
                           FontSize="18"
                           VerticalOptions="Center"/>

                    <Entry x:Name="SearchEntry"
                           Placeholder="{Binding SearchPlaceholder}"
                           Grid.Column="1"
                           FontSize="14"
                           VerticalOptions="Center"
                           Margin="10,0,0,0"/>

                    <Border Grid.Column="2"
                            BackgroundColor="#EEE"
                            StrokeShape="RoundRectangle 15"
                            Padding="10,5">

                        <Label x:Name="LanguageLabel"
                               Text="{Binding LanguageCode}"
                               FontSize="10"
                               VerticalOptions="Center"/>

                    </Border>

                </Grid>

            </Border>

            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    Padding="12,8"
                    Margin="20,100,20,0"
                    AbsoluteLayout.LayoutBounds="0.5,0,0.9,50"
                    AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional"
                    HorizontalOptions="Center">

                <Label x:Name="RadiusDisplayLabel"
                       Text="{Binding RadiusDisplayText}"
                       FontSize="12"
                       TextColor="#2C1810"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>
            </Border>

            <!-- Nút GPS -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 30"
                    HeightRequest="45"
                    WidthRequest="45"
                    AbsoluteLayout.LayoutBounds="0.95,0.85,45,45"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    x:Name="GpsButton">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGpsButtonTapped"/>
                </Border.GestureRecognizers>
                <Label Text="📍" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="20"/>
            </Border>

        </AbsoluteLayout>

        <!-- THẺ THÔNG TIN -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                Padding="20">

            <VerticalStackLayout Spacing="10">

                <Label
                    x:Name="NearbyLabel"
                    Text="{Binding NearbyText}"
                    TextColor="#E85C2B"
                    FontSize="12" />

                <Label
                    x:Name="PoiNameLabel"
                    Text="{Binding PoiNameText}"
                    FontSize="18"
                    FontAttributes="Bold" 
                    TextColor="#2C1810" />

                <Label
                    x:Name="ListenTextLabel"
                    Text="{Binding ListenText}"
                    FontSize="13"
                    TextColor="#9E8B7E" />
                <Button
                    x:Name="PlayButton"
                    Text="{Binding PlayButtonText}"
                    BackgroundColor="#E85C2B"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="45"
                    Clicked="OnPlayButtonClicked" />

            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentPage>