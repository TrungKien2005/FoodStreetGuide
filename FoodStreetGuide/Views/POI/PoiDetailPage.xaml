<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="doanC_.Views.PoiDetailPage"
             Title="Chi tiết địa điểm"
             BackgroundColor="#1A1A1A">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="15">

            <!-- Image Card with Controls -->
            <Border Padding="0" 
                   Stroke="Transparent"
                   BackgroundColor="#3D2817"
                   Margin="0,0,0,20"
                   StrokeThickness="0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto,Auto,Auto">

                    <!-- Main Image -->
                    <Image Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                           x:Name="MainImage"
                           Source="poi_default.png"
                           Aspect="AspectFill"
                           HeightRequest="280"
                           ZIndex="0"/>

                    <!-- Back Button -->
                    <Button Grid.Row="0" Grid.Column="0"
                            Text="‹"
                            BackgroundColor="#6B4423"
                            TextColor="White"
                            FontSize="24"
                            WidthRequest="45"
                            HeightRequest="45"
                            CornerRadius="22"
                            Margin="10,10,0,0"
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            Clicked="OnBackButtonClicked"
                            Padding="0"
                            ZIndex="1"/>

                    <!-- Right Controls -->
                    <VerticalStackLayout Grid.Row="0" Grid.Column="4"
                                       Spacing="10"
                                       HorizontalOptions="End"
                                       VerticalOptions="Start"
                                       Margin="0,10,10,0"
                                       ZIndex="1">

                        <!-- Favorite Button -->
                        <Button Text="❤️"
                                BackgroundColor="#6B4423"
                                TextColor="White"
                                FontSize="20"
                                WidthRequest="45"
                                HeightRequest="45"
                                CornerRadius="22"
                                Padding="0"
                                Clicked="OnFavoriteClicked"/>

                        <!-- Share Button -->
                        <Button Text="🔗"
                                BackgroundColor="#6B4423"
                                TextColor="White"
                                FontSize="20"
                                WidthRequest="45"
                                HeightRequest="45"
                                CornerRadius="22"
                                Padding="0"
                                Clicked="OnShareClicked"/>
                    </VerticalStackLayout>

                    <!-- Dots Indicator -->
                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
                                          HorizontalOptions="Center"
                                          Spacing="5"
                                          Margin="0,10,0,10">
                        <BoxView WidthRequest="6" HeightRequest="3" CornerRadius="2" Color="White"/>
                        <BoxView WidthRequest="3" HeightRequest="3" CornerRadius="2" Color="#999999"/>
                        <BoxView WidthRequest="3" HeightRequest="3" CornerRadius="2" Color="#999999"/>
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <!-- Content Card -->
            <Border Padding="20" 
                   Stroke="Transparent"
                   BackgroundColor="#2D2D2D"
                   StrokeThickness="0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="15">

                    <!-- Category -->
                    <Label x:Name="CategoryLabel"
                           FontSize="11"
                           TextColor="#FF9500"
                           FontAttributes="Bold"/>

                    <!-- POI Name -->
                    <Label x:Name="PoiNameLabel"
                           FontSize="24"
                           TextColor="White"
                           FontAttributes="Bold"
                           LineBreakMode="WordWrap"/>

                    <!-- Rating -->
                    <Label x:Name="RatingLabel"
                           FontSize="14"
                           TextColor="#FF9500"
                           FontAttributes="Bold"/>

                    <!-- Address -->
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍"
                               FontSize="16"
                               VerticalOptions="Start"/>
                        <Label x:Name="AddressLabel"
                               FontSize="13"
                               TextColor="#CCCCCC"
                               LineBreakMode="WordWrap"
                               VerticalOptions="Start"/>
                    </HorizontalStackLayout>

                    <!-- Phone -->
                    <HorizontalStackLayout x:Name="PhoneRow" Spacing="8" IsVisible="False">
                        <Label Text="📞"
                               FontSize="16"
                               VerticalOptions="Center"/>
                        <Label x:Name="PhoneLabel"
                               FontSize="13"
                               TextColor="#4FC3F7"
                               VerticalOptions="Center"
                               TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPhoneCallTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Description -->
                    <Label x:Name="DescriptionLabel"
                           FontSize="14"
                           TextColor="#CCCCCC"
                           LineBreakMode="WordWrap"/>

                    <!-- Opening Hours -->
                    <Border Padding="12,10"
                           StrokeThickness="1"
                           Stroke="#555555"
                           BackgroundColor="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Label x:Name="OpeningHoursLabel"
                               FontSize="13"
                               TextColor="White"
                               HorizontalOptions="Center"
                               FontAttributes="Bold"/>
                    </Border>

                    <!-- Price Range -->
                    <Border Padding="12,10"
                           StrokeThickness="1"
                           Stroke="#555555"
                           BackgroundColor="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Label x:Name="PriceLabel"
                               FontSize="13"
                               TextColor="White"
                               HorizontalOptions="Center"
                               FontAttributes="Bold"/>
                    </Border>

                    <!-- Status Button -->
                    <Button x:Name="OpenStatusButton"
                            Text="Đang mở"
                            BackgroundColor="#00AA44"
                            TextColor="White"
                            FontSize="14"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="45"
                            Clicked="OnOpenStatusClicked"/>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                        <Button Grid.Column="0"
                                x:Name="AudioButton"
                                Text="🔊 Nghe thuyết minh"
                                BackgroundColor="#333333"
                                TextColor="White"
                                FontSize="14"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                HeightRequest="45"
                                Clicked="OnPlayAudioClicked"/>

                        <Button Grid.Column="1"
                                x:Name="DirectionsButton"
                                Text="🗺️ Chỉ đường"
                                BackgroundColor="#FF6B35"
                                TextColor="White"
                                FontSize="14"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                HeightRequest="45"
                                Clicked="OnGetDirectionsClicked"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Audio Player (Hidden by default) -->
            <Border x:Name="AudioPlayerFrame"
                   Padding="20"
                   StrokeThickness="0"
                   BackgroundColor="#2D2D2D"
                   Margin="0,15,0,0"
                   IsVisible="False">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="15">
                    <Label x:Name="AudioPlayerLabel"
                           FontSize="16"
                           TextColor="White"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>

                    <Picker x:Name="AudioLanguagePicker"
                            Title="Chọn ngôn ngữ"
                            TextColor="White"
                            BackgroundColor="#333333">
                        <Picker.Items>
                            <x:String>Tiếng Việt</x:String>
                            <x:String>English</x:String>
                            <x:String>中文</x:String>
                            <x:String>日本語</x:String>
                            <x:String>한국어</x:String>
                        </Picker.Items>
                    </Picker>

                    <Button x:Name="PlayPauseButton"
                            Text="▶ Phát"
                            BackgroundColor="#FF6B35"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="45"
                            Clicked="OnPlayPauseClicked"/>

                    <ProgressBar x:Name="AudioProgress"
                                 Progress="0"
                                 ProgressColor="#FF6B35"
                                 HeightRequest="4"/>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label x:Name="CurrentTimeLabel"
                               Text="0:00"
                               FontSize="12"
                               TextColor="#999999"/>
                        <Label Text="/"
                               FontSize="12"
                               TextColor="#999999"/>
                        <Label x:Name="TotalTimeLabel"
                               Text="0:00"
                               FontSize="12"
                               TextColor="#999999"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>