@page "{currentPage:int?}"
@model doanC_Admin.Pages.LocationPoints.IndexModel
@{
    ViewData["Title"] = "Quản lý địa điểm";
}

<style>
    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

    .table-custom {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .table-custom thead th {
            background: #1a1a2e;
            color: white;
            padding: 1rem;
            font-weight: 600;
            font-size: 0.85rem;
        }

            .table-custom thead th:first-child {
                border-radius: 12px 0 0 0;
            }

            .table-custom thead th:last-child {
                border-radius: 0 12px 0 0;
            }

        .table-custom tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #ecf0f1;
        }

        .table-custom tbody tr:hover {
            background: #FFF3E0;
        }

    .action-column {
        padding-left: 0px !important;
        padding-right: 0px !important;
    }

    .action-buttons {
        display: flex;
        gap: 12px;
        justify-content: center;
        align-items: center;
    }

    .btn-edit, .btn-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        text-decoration: none;
        transition: transform 0.2s ease;
    }

        .btn-edit:hover, .btn-delete:hover {
            transform: translateY(-4px);
        }


    .btn-edit {
        background-color: #ffc107;
        color: #212529;
    }

    .btn-delete {
        background-color: #dc3545;
        color: white;
    }

        .btn-edit i, .btn-delete i {
            font-size: 16px;
        }

    .pagination .page-link {
        color: #FF5722;
        border-radius: 8px;
        margin: 0 3px;
    }

    .pagination .active .page-link {
        background: linear-gradient(135deg, #FF5722, #E64A19);
        border-color: #FF5722;
        color: white;
    }

    .badge-category {
        background: #FFF3E0;
        color: #FF5722;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
    }

    .coordinate {
        font-family: monospace;
        font-size: 0.8rem;
        color: #6c757d;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title">
        <i class="fas fa-map-marker-alt me-2" style="color: #FF5722;"></i>Quản lý địa điểm
    </h2>
    <a href="/LocationPoints/Create" class="btn btn-gradient">
        <i class="fas fa-plus me-2"></i>Thêm địa điểm
    </a>
</div>

<div class="stat-card">
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên địa điểm</th>
                    <th>Danh mục</th>
                    <th>Tọa độ</th>
                    <th style="width: 100px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.LocationPoints)
                {
                    <tr>
                        <td class="fw-bold">@item.PointId</td>
                        <td>@item.Name</td>
                        <td><span class="badge-category">@(item.Category ?? "Chưa phân loại")</span></td>
                        <td class="coordinate">
                            @item.Latitude.ToString("F6"), @item.Longitude.ToString("F6")
                        </td>
                        <td class="action-column">
                            <a asp-page="./Edit" asp-route-id="@item.PointId" class="btn-edit">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-page="./Delete" asp-route-id="@item.PointId" class="btn-delete">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-page="./Index" asp-route-currentPage="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>