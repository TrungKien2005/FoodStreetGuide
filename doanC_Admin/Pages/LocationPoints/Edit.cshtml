@page "{id:int?}"
@model doanC_Admin.Pages.LocationPoints.EditModel
@{
    ViewData["Title"] = "Sửa địa điểm";
}

<style>
    .form-container {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

    .form-label {
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border-radius: 10px;
        border: 1px solid #e0e0e0;
        padding: 0.6rem 1rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: #FF5722;
            box-shadow: 0 0 0 3px rgba(255,87,34,0.1);
        }

    .btn-save {
        background: linear-gradient(135deg, #FF5722, #E64A19);
        border: none;
        padding: 0.6rem 2rem;
        border-radius: 10px;
        font-weight: 600;
    }

    .geocode-btn {
        background: #f8f9fa;
        border: 1px solid #e0e0e0;
        color: #FF5722;
        border-radius: 8px;
        padding: 0.3rem 1rem;
    }

    .current-image {
        max-width: 150px;
        max-height: 150px;
        border-radius: 12px;
        border: 2px solid #e0e0e0;
    }
</style>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">✏️ Sửa địa điểm</h2>
        <a href="/LocationPoints" class="btn btn-outline-gradient">
            <i class="fas fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>

    <div class="form-container">
        <form method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="LocationPoint.PointId" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="LocationPoint.Name" class="form-label">Tên địa điểm <span class="text-danger">*</span></label>
                    <input asp-for="LocationPoint.Name" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="LocationPoint.Category" class="form-label">Danh mục</label>
                    <select asp-for="LocationPoint.Category" class="form-select" asp-items="Model.Categories">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                </div>

                <div class="col-12 mb-3">
                    <label asp-for="LocationPoint.Description" class="form-label">Mô tả</label>
                    <textarea asp-for="LocationPoint.Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="LocationPoint.Address" class="form-label">Địa chỉ</label>
                    <div class="input-group">
                        <input asp-for="LocationPoint.Address" class="form-control" id="addressInput" />
                        <button type="button" id="geocodeBtn" class="geocode-btn">
                            <i class="fas fa-map-pin"></i> Lấy tọa độ
                        </button>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <label asp-for="LocationPoint.Latitude" class="form-label">Vĩ độ</label>
                    <input asp-for="LocationPoint.Latitude" class="form-control" step="any" />
                </div>

                <div class="col-md-3 mb-3">
                    <label asp-for="LocationPoint.Longitude" class="form-label">Kinh độ</label>
                    <input asp-for="LocationPoint.Longitude" class="form-control" step="any" />
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="LocationPoint.Rating" class="form-label">Đánh giá</label>
                    <input asp-for="LocationPoint.Rating" class="form-control" step="0.1" min="0" max="5" />
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="LocationPoint.ReviewCount" class="form-label">Số đánh giá</label>
                    <input asp-for="LocationPoint.ReviewCount" class="form-control" type="number" />
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="LocationPoint.PriceRange" class="form-label">Khoảng giá</label>
                    <input asp-for="LocationPoint.PriceRange" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="LocationPoint.OpeningHours" class="form-label">Giờ mở cửa</label>
                    <input asp-for="LocationPoint.OpeningHours" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Hình ảnh</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                    <small class="text-muted">Để trống nếu không muốn thay đổi ảnh</small>
                </div>

                @if (!string.IsNullOrEmpty(Model.LocationPoint.Image))
                {
                    <div class="col-12 mb-3">
                        <label class="form-label">Ảnh hiện tại</label>
                        <div>
                            <img src="/images/@Model.LocationPoint.Image" class="current-image" />
                            <input type="hidden" asp-for="LocationPoint.Image" />
                        </div>
                    </div>
                }
            </div>

            <hr class="my-4" />

            <div class="d-flex justify-content-end gap-3">
                <a asp-page="./Index" class="btn btn-cancel">
                    <i class="fas fa-times me-2"></i>Hủy bỏ
                </a>
                <button type="submit" class="btn btn-save">
                    <i class="fas fa-save me-2"></i>Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById('geocodeBtn')?.addEventListener('click', async function() {
            const address = document.getElementById('addressInput').value;
            if (!address) {
                alert('Vui lòng nhập địa chỉ trước');
                return;
            }

            this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lấy...';
            this.disabled = true;

            try {
                const response = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(address)}&format=json&limit=1`);
                const data = await response.json();

                if (data && data.length > 0) {
                    document.querySelector('#LocationPoint_Latitude').value = parseFloat(data[0].lat);
                    document.querySelector('#LocationPoint_Longitude').value = parseFloat(data[0].lon);
                    alert('✅ Đã lấy tọa độ thành công!');
                } else {
                    alert('❌ Không tìm thấy tọa độ');
                }
            } catch (error) {
                alert('❌ Lỗi khi lấy tọa độ');
            } finally {
                this.innerHTML = '<i class="fas fa-map-pin"></i> Lấy tọa độ';
                this.disabled = false;
            }
        });
    </script>
}