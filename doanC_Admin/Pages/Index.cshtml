@page
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FoodStreetGuide Admin</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
        }

        .loading-container {
            text-align: center;
            animation: fadeIn 0.5s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .logo-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #FF5722, #E64A19);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            box-shadow: 0 20px 40px rgba(255, 87, 34, 0.3);
            animation: pulse 2s ease-in-out infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.05);
            }
        }

        .logo-icon i {
            font-size: 3rem;
            color: white;
        }

        .logo h2 {
            font-size: 1.8rem;
            background: linear-gradient(135deg, #FF5722, #FF9800);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .dot-loader {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin: 2rem 0;
        }

        .dot {
            width: 18px;
            height: 18px;
            background: linear-gradient(135deg, #FF5722, #E64A19);
            border-radius: 50%;
            animation: bounce 0.6s ease-in-out infinite;
        }

            .dot:nth-child(1) {
                animation-delay: 0s;
            }

            .dot:nth-child(2) {
                animation-delay: 0.15s;
            }

            .dot:nth-child(3) {
                animation-delay: 0.3s;
            }

        @@keyframes bounce {
            0%, 80%, 100% {
                transform: translateY(0);
                opacity: 0.6;
            }

            40% {
                transform: translateY(-25px);
                opacity: 1;
            }
        }

        .loading-text {
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
            margin-top: 1rem;
        }

        @@media (max-width: 480px) {
            .logo-icon {
                width: 60px;
                height: 60px;
            }

                .logo-icon i {
                    font-size: 2rem;
                }

            .logo h2 {
                font-size: 1.4rem;
            }

            .dot {
                width: 14px;
                height: 14px;
            }
        }
    </style>
</head>
<body>
    <div class="loading-container">
        <div class="logo">
            <div class="logo-icon">
                <i class="fas fa-utensils"></i>
            </div>
            <h2>FoodStreetGuide</h2>
        </div>

        <div class="dot-loader">
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
        </div>

        <div class="loading-text">
            Đang chuyển hướng...
        </div>
    </div>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <script>
        // Redirect to Login after 1.5 seconds
        setTimeout(function() {
            window.location.href = '/Login';
        }, 1500);
    </script>
</body>
</html>