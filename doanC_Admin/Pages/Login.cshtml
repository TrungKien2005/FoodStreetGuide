@page
@model LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập - FoodStreetGuide";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - FoodStreetGuide Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            position: relative;
            overflow-x: hidden;
        }

        /* Animated Background */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
        }

            .bg-animation span {
                position: absolute;
                width: 200px;
                height: 200px;
                background: linear-gradient(135deg, rgba(255,87,34,0.1), rgba(255,87,34,0.05));
                border-radius: 50%;
                animation: moveBubble 25s infinite linear;
            }

        @@keyframes moveBubble {
            0%

        {
            transform: translate(-100%, -100%) scale(1);
            opacity: 0;
        }

        10% {
            opacity: 0.5;
        }

        90% {
            opacity: 0.5;
        }

        100% {
            transform: translate(200%, 200%) scale(3);
            opacity: 0;
        }

        }

        /* Login Card */
        .login-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 48px;
            padding: 2.5rem;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 40px 60px -20px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.1);
            position: relative;
            z-index: 10;
            backdrop-filter: blur(20px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            animation: slideIn 0.6s ease-out;
        }

            .login-card:hover {
                transform: translateY(-8px) scale(1.01);
                box-shadow: 0 50px 80px -25px rgba(0, 0, 0, 0.5);
            }

        @@keyframes slideIn {
            from

        {
            opacity: 0;
            transform: translateY(50px) scale(0.95);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        }

        /* Glass Effect */
        .login-card::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            border-radius: 50px;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .login-card:hover::before {
            opacity: 0.5;
        }

        /* Logo Section */
        .login-logo {
            text-align: center;
            margin-bottom: 2rem;
        }

        .logo-wrapper {
            position: relative;
            display: inline-block;
        }

        .logo-icon {
            width: 85px;
            height: 85px;
            background: linear-gradient(135deg, #FF5722, #E64A19);
            border-radius: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            box-shadow: 0 15px 30px rgba(255, 87, 34, 0.3);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
        }

            .logo-icon::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
                transition: left 0.5s ease;
            }

        .login-card:hover .logo-icon::before {
            left: 100%;
        }

        .login-card:hover .logo-icon {
            transform: scale(1.05) rotate(5deg);
            border-radius: 32px;
            box-shadow: 0 20px 40px rgba(255, 87, 34, 0.4);
        }

        .logo-icon i {
            font-size: 3rem;
            color: white;
            transition: transform 0.3s ease;
        }

        .login-card:hover .logo-icon i {
            transform: scale(1.1);
        }

        .login-logo h3 {
            font-weight: 800;
            font-size: 1.85rem;
            background: linear-gradient(135deg, #FF5722, #E64A19, #FF9800);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 0.25rem;
            letter-spacing: -0.5px;
        }

        .login-logo p {
            font-size: 0.8rem;
            color: #6c757d;
            margin-bottom: 0;
        }

        /* Alert Styles */
        .alert-custom {
            border-radius: 24px;
            border: none;
            padding: 1rem 1.25rem;
            font-size: 0.85rem;
            animation: shake 0.5s ease;
            backdrop-filter: blur(10px);
            background: linear-gradient(135deg, #f8d7da, #f5c6cb);
            border-left: 4px solid #dc3545;
        }

        @@keyframes shake {
            0%, 100%

        {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-8px);
        }

        75% {
            transform: translateX(8px);
        }

        }

        /* Form Styles */
        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 0.6rem;
            color: #2c3e50;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .form-label i {
                color: #FF5722;
                font-size: 0.9rem;
            }

        .input-group-custom {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-group-text-custom {
            position: absolute;
            left: 18px;
            color: #adb5bd;
            z-index: 10;
            transition: all 0.3s ease;
        }

        .form-control-custom {
            width: 100%;
            padding: 1rem 1rem 1rem 3rem;
            border: 2px solid #e9ecef;
            border-radius: 28px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            background: white;
        }

            .form-control-custom:focus {
                outline: none;
                border-color: #FF5722;
                box-shadow: 0 0 0 5px rgba(255, 87, 34, 0.1);
                transform: translateY(-2px);
            }

            .form-control-custom:hover {
                border-color: #FF5722;
                transform: translateY(-1px);
            }

        /* Password Toggle */
        .password-toggle {
            position: absolute;
            right: 18px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #adb5bd;
            transition: all 0.3s ease;
            z-index: 10;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }

            .password-toggle:hover {
                color: #FF5722;
                background: rgba(255, 87, 34, 0.1);
                transform: translateY(-50%) scale(1.1);
            }

        /* Login Button */
        .btn-login {
            background: linear-gradient(135deg, #FF5722, #E64A19);
            border: none;
            padding: 1rem;
            font-weight: 700;
            font-size: 1rem;
            width: 100%;
            border-radius: 32px;
            color: white;
            position: relative;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
            margin-top: 0.5rem;
        }

            .btn-login::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
                transition: left 0.5s ease;
            }

            .btn-login:hover::before {
                left: 100%;
            }

            .btn-login:hover {
                transform: translateY(-3px);
                box-shadow: 0 15px 30px rgba(255, 87, 34, 0.4);
            }

            .btn-login:active {
                transform: translateY(0);
            }

            .btn-login i {
                transition: transform 0.3s ease;
            }

            .btn-login:hover i {
                transform: translateX(5px);
            }

            /* Loading State */
            .btn-login.loading {
                pointer-events: none;
                opacity: 0.7;
            }

                .btn-login.loading .btn-text {
                    display: none;
                }

                .btn-login.loading .loading-spinner {
                    display: inline-block;
                }

        .loading-spinner {
            display: none;
            width: 22px;
            height: 22px;
            border: 2px solid white;
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin-right: 8px;
        }

        @@keyframes spin {
            to

        {
            transform: rotate(360deg);
        }

        }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 1.8rem 0;
            color: #adb5bd;
            font-size: 0.75rem;
        }

            .divider::before,
            .divider::after {
                content: '';
                flex: 1;
                border-bottom: 2px dashed #e9ecef;
            }

            .divider::before {
                margin-right: 1rem;
            }

            .divider::after {
                margin-left: 1rem;
            }

        /* Role Badges */
        .role-badges {
            display: flex;
            justify-content: center;
            gap: 0.75rem;
            margin-top: 1rem;
            flex-wrap: wrap;
        }

        .role-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.35rem 1rem;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 600;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: default;
        }

            .role-badge:hover {
                transform: translateY(-3px) scale(1.05);
            }

            .role-badge i {
                font-size: 0.7rem;
            }

        .role-admin {
            background: linear-gradient(135deg, #dc3545, #c82333);
            color: white;
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

        .role-manager {
            background: linear-gradient(135deg, #28a745, #20c997);
            color: white;
            box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        }

        .role-viewer {
            background: linear-gradient(135deg, #6c757d, #5a6268);
            color: white;
            box-shadow: 0 4px 12px rgba(108, 117, 125, 0.3);
        }

        /* Footer */
        .footer-text {
            text-align: center;
            margin-top: 1.8rem;
            font-size: 0.7rem;
            color: #adb5bd;
        }

            .footer-text i {
                margin-right: 0.25rem;
                transition: transform 0.3s ease;
            }

            .footer-text:hover i {
                transform: scale(1.2);
                color: #FF5722;
            }

        /* Floating Animation for Card */
        @@keyframes float {
            0%, 100%

        {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-10px);
        }

        }

        .login-card {
            animation: slideIn 0.6s ease-out, float 6s ease-in-out infinite;
            animation-delay: 0s, 0.6s;
        }

        /* Responsive */
        @@media (max-width: 480px) {
            .login-card {
                margin: 1rem;
                padding: 1.8rem;
                border-radius: 32px;
            }

            .logo-icon {
                width: 65px;
                height: 65px;
            }

                .logo-icon i {
                    font-size: 2.2rem;
                }

            .login-logo h3 {
                font-size: 1.5rem;
            }
        }

        /* Input Focus Glow */
        .form-control-custom:focus {
            animation: glow 0.3s ease;
        }

        @@keyframes glow {
            0%

        {
            box-shadow: 0 0 0 0 rgba(255, 87, 34, 0.4);
        }

        100% {
            box-shadow: 0 0 0 5px rgba(255, 87, 34, 0.1);
        }

        }
    </style>
</head>
<body>
    <!-- Animated Background Bubbles -->
    <div class="bg-animation" id="bgAnimation"></div>

    <div class="login-card">
        <div class="login-logo">
            <div class="logo-wrapper">
                <div class="logo-icon">
                    <i class="fas fa-utensils"></i>
                </div>
            </div>
            <h3>FoodStreetGuide</h3>
            <p>Hệ thống quản lý ẩm thực đường phố</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-custom alert-danger" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> @Model.ErrorMessage
            </div>
        }

        <form method="post" id="loginForm">
            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-user"></i>
                    Tên đăng nhập
                </label>
                <div class="input-group-custom">
                    <span class="input-group-text-custom">
                        <i class="fas fa-envelope"></i>
                    </span>
                    <input type="text"
                           name="Username"
                           class="form-control-custom"
                           placeholder="Nhập tên đăng nhập"
                           required
                           autofocus />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-lock"></i>
                    Mật khẩu
                </label>
                <div class="input-group-custom">
                    <span class="input-group-text-custom">
                        <i class="fas fa-key"></i>
                    </span>
                    <input type="password"
                           name="Password"
                           id="password"
                           class="form-control-custom"
                           placeholder="Nhập mật khẩu"
                           required />
                    <span class="password-toggle" onclick="togglePassword()">
                        <i class="far fa-eye" id="toggleIcon"></i>
                    </span>
                </div>
            </div>

            <button type="submit" class="btn-login" id="loginBtn">
                <span class="loading-spinner"></span>
                <span class="btn-text">
                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                </span>
            </button>
        </form>

        <div class="divider">
            <span>Phân quyền truy cập</span>
        </div>

        <div class="role-badges">
            <span class="role-badge role-admin">
                <i class="fas fa-crown"></i> Admin
            </span>
            <span class="role-badge role-manager">
                <i class="fas fa-store"></i> Chủ quán
            </span>
            <span class="role-badge role-viewer">
                <i class="fas fa-eye"></i> Viewer
            </span>
        </div>

        <div class="footer-text">
            <i class="fas fa-shield-alt"></i> Hệ thống quản lý ẩm thực đường phố
        </div>
    </div>

    <script>
        // Toggle Password Visibility
        function togglePassword() {
            const password = document.getElementById('password');
            const icon = document.getElementById('toggleIcon');

            if (password.type === 'password') {
                password.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                password.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        // Loading State on Submit
        const form = document.getElementById('loginForm');
        const loginBtn = document.getElementById('loginBtn');

        form.addEventListener('submit', function(e) {
            const username = document.querySelector('input[name="Username"]').value;
            const password = document.querySelector('input[name="Password"]').value;

            if (!username || !password) {
                e.preventDefault();
                return;
            }

            loginBtn.classList.add('loading');
        });

        // Create Animated Bubbles
        function createBubbles() {
            const container = document.getElementById('bgAnimation');
            const bubbleCount = 30;

            for (let i = 0; i < bubbleCount; i++) {
                const bubble = document.createElement('span');
                const size = Math.random() * 150 + 50;
                const left = Math.random() * 100;
                const duration = Math.random() * 20 + 15;
                const delay = Math.random() * 10;

                bubble.style.width = size + 'px';
                bubble.style.height = size + 'px';
                bubble.style.left = left + '%';
                bubble.style.animationDuration = duration + 's';
                bubble.style.animationDelay = delay + 's';
                bubble.style.background = `linear-gradient(135deg, rgba(255,87,34,${Math.random() * 0.1 + 0.05}), rgba(255,87,34,${Math.random() * 0.05 + 0.02}))`;

                container.appendChild(bubble);
            }
        }

        createBubbles();

        // Auto-dismiss alert after 5 seconds
        setTimeout(function() {
            const alert = document.querySelector('.alert-custom');
            if (alert) {
                alert.style.transition = 'all 0.5s ease';
                alert.style.opacity = '0';
                alert.style.transform = 'translateX(50px)';
                setTimeout(() => {
                    if (alert.parentNode) alert.remove();
                }, 500);
            }
        }, 5000);

        // Ripple effect on button
        const btn = document.querySelector('.btn-login');
        btn.addEventListener('click', function(e) {
            if (this.classList.contains('loading')) return;

            const rect = this.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;

            const ripple = document.createElement('span');
            ripple.style.position = 'absolute';
            ripple.style.width = '0px';
            ripple.style.height = '0px';
            ripple.style.backgroundColor = 'rgba(255,255,255,0.6)';
            ripple.style.borderRadius = '50%';
            ripple.style.transform = 'translate(-50%, -50%)';
            ripple.style.left = x + 'px';
            ripple.style.top = y + 'px';
            ripple.style.animation = 'ripple 0.6s linear';
            ripple.style.pointerEvents = 'none';

            this.style.position = 'relative';
            this.style.overflow = 'hidden';
            this.appendChild(ripple);

            setTimeout(() => {
                ripple.remove();
            }, 600);
        });

        // Add ripple animation
        const style = document.createElement('style');
        style.textContent = `
            @@keyframes ripple {
                0% {
                    width: 0px;
                    height: 0px;
                    opacity: 0.5;
                }
                100% {
                    width: 400px;
                    height: 400px;
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>