<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FoodStreetGuide Owner</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-orange: #FF5722;
            --primary-orange-dark: #E64A19;
            --sidebar-bg: #1a1a2e;
            --sidebar-dark: #16213e;
            --border-radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f0f2f5;
            overflow-x: hidden;
        }

        /* Sidebar Owner */
        .sidebar {
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
            width: 280px;
            min-height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            transition: var(--transition);
            z-index: 1000;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.1);
        }

        .sidebar-header {
            padding: 28px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            margin-bottom: 20px;
            text-align: center;
        }

        .sidebar-logo {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #FF5722, #FF8A65);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        .sidebar-header h4 {
            font-size: 1.25rem;
            font-weight: 700;
            color: white;
            margin-bottom: 5px;
        }

        .sidebar-header small {
            font-size: 0.7rem;
            color: #a0aec0;
        }

        .sidebar .nav-item {
            margin: 5px 15px;
        }

        .sidebar .nav-link {
            color: #cbd5e1;
            padding: 12px 16px;
            border-radius: 12px;
            transition: var(--transition);
            font-weight: 500;
            font-size: 0.85rem;
        }

            .sidebar .nav-link:hover {
                background: rgba(255, 87, 34, 0.15);
                color: #FF5722;
                transform: translateX(5px);
            }

            .sidebar .nav-link.active {
                background: linear-gradient(135deg, #FF5722, #E64A19);
                color: white;
                box-shadow: 0 5px 15px rgba(255, 87, 34, 0.3);
            }

            .sidebar .nav-link i {
                width: 28px;
                margin-right: 12px;
                font-size: 1rem;
                text-align: center;
            }

            .sidebar .nav-link.logout {
                color: #ff6b6b;
                margin-top: 30px;
            }

                .sidebar .nav-link.logout:hover {
                    background: rgba(255, 107, 107, 0.15);
                    color: #ff6b6b;
                }

        .main-content {
            margin-left: 280px;
            padding: 20px 25px;
            min-height: 100vh;
            background: #f0f2f5;
        }

        .top-bar {
            background: white;
            border-radius: var(--border-radius);
            padding: 15px 25px;
            margin-bottom: 25px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .page-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 4px;
        }

        .page-subtitle {
            font-size: 0.75rem;
            color: #7f8c8d;
        }

        .user-avatar {
            width: 42px;
            height: 42px;
            background: linear-gradient(135deg, #FF5722, #E64A19);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            cursor: pointer;
        }

        @@media (max-width: 768px) {
            .sidebar {
                width: 80px;
            }

                .sidebar-header h4, .sidebar-header small, .sidebar .nav-link span {
                    display: none;
                }

                .sidebar .nav-link i {
                    margin-right: 0;
                    font-size: 1.2rem;
                }

            .main-content {
                margin-left: 80px;
                padding: 15px;
            }
        }
    </style>
</head>
<body>

    <!-- Sidebar Owner -->
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <i class="fas fa-utensils"></i>
            </div>
            <h4>FoodStreetGuide</h4>
            <small>Khu vực Chủ quán</small>
        </div>

        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Dashboard") == true ? "active" : "")"
                   asp-page="/Owner/Dashboard">
                    <i class="fas fa-chart-line"></i>
                    <span>Tổng quan</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("MyLocations") == true ? "active" : "")"
                   asp-page="/Owner/MyLocations">
                    <i class="fas fa-store"></i>
                    <span>Quản lý địa điểm</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("RegisterPoi") == true ? "active" : "")"
                   asp-page="/Owner/RegisterPoi">
                    <i class="fas fa-plus-circle"></i>
                    <span>Đăng ký địa điểm</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("MyAudios") == true ? "active" : "")"
                   asp-page="/Owner/MyAudios">
                    <i class="fas fa-headphones"></i>
                    <span>Quản lý Audio</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Statistics") == true ? "active" : "")"
                   asp-page="/Owner/Statistics">
                    <i class="fas fa-chart-bar"></i>
                    <span>Thống kê</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link logout" asp-page="/Logout">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Đăng xuất</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="top-bar d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0 page-title">@ViewData["Title"]</h5>
                <div class="page-subtitle">
                    <i class="fas fa-calendar-alt me-1"></i> @DateTime.Now.ToString("dddd, dd/MM/yyyy")
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="user-avatar">
                    <i class="fas fa-store"></i>
                </div>
                <span class="text-muted small">@Context.Session.GetString("Username")</span>
            </div>
        </div>

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>