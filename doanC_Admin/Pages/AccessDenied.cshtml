@page
@{
    Layout = null;
    ViewData["Title"] = "Truy cập bị từ chối";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied - FoodStreetGuide Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
        }

        .access-denied-card {
            background: white;
            border-radius: 32px;
            padding: 3rem;
            text-align: center;
            max-width: 500px;
            animation: fadeIn 0.5s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .icon-circle {
            width: 100px;
            height: 100px;
            background: #fee2e2;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }

            .icon-circle i {
                font-size: 3rem;
                color: #dc3545;
            }

        h2 {
            color: #dc3545;
            margin-bottom: 1rem;
        }

        p {
            color: #6c757d;
            margin-bottom: 1.5rem;
        }

        .btn-gradient {
            background: linear-gradient(135deg, #FF5722, #E64A19);
            border: none;
            color: white;
            padding: 0.75rem 2rem;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(255,87,34,0.3);
                color: white;
            }

        .btn-outline {
            background: transparent;
            border: 2px solid #6c757d;
            color: #6c757d;
            padding: 0.7rem 1.8rem;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s;
            margin-left: 0.5rem;
        }

            .btn-outline:hover {
                background: #6c757d;
                color: white;
            }
    </style>
</head>
<body>
    <div class="access-denied-card">
        <div class="icon-circle">
            <i class="fas fa-ban"></i>
        </div>
        <h2><i class="fas fa-lock me-2"></i> Truy cập bị từ chối</h2>
        <p>Bạn không có quyền truy cập vào trang này.<br />Vui lòng liên hệ quản trị viên nếu cần hỗ trợ.</p>
        <div>
            <a href="/Dashboard" class="btn btn-gradient">
                <i class="fas fa-home me-2"></i> Về trang chủ
            </a>
            <a href="/Logout" class="btn btn-outline">
                <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
            </a>
        </div>
    </div>
</body>
</html>