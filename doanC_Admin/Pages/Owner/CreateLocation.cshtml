@page
@model doanC_Admin.Pages.Owner.CreateLocationModel
@{
    ViewData["Title"] = "Đăng ký địa điểm mới";
    Layout = "_Layout";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">
            <i class="fas fa-plus-circle me-2" style="color: #FF5722;"></i>Đăng ký địa điểm mới
        </h2>
        <a href="/Owner/Dashboard" class="btn btn-outline-gradient">
            <i class="fas fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>

    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>
        Địa điểm của bạn sẽ được gửi đến Admin để duyệt. Sau khi được duyệt, địa điểm sẽ hiển thị trên ứng dụng.
    </div>

    <form method="post" enctype="multipart/form-data">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="LocationPoint.Name" class="form-label">Tên địa điểm *</label>
                <input asp-for="LocationPoint.Name" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="LocationPoint.Category" class="form-label">Danh mục</label>
                <select asp-for="LocationPoint.Category" class="form-select" asp-items="Model.Categories">
                    <option value="">-- Chọn danh mục --</option>
                </select>
            </div>
            <div class="col-12 mb-3">
                <label asp-for="LocationPoint.Description" class="form-label">Mô tả</label>
                <textarea asp-for="LocationPoint.Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="LocationPoint.Address" class="form-label">Địa chỉ</label>
                <input asp-for="LocationPoint.Address" class="form-control" id="addressInput" />
                <button type="button" id="geocodeBtn" class="btn btn-sm btn-secondary mt-1">
                    <i class="fas fa-map-pin"></i> Lấy tọa độ
                </button>
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="LocationPoint.Latitude" class="form-label">Vĩ độ</label>
                <input asp-for="LocationPoint.Latitude" class="form-control" step="any" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="LocationPoint.Longitude" class="form-label">Kinh độ</label>
                <input asp-for="LocationPoint.Longitude" class="form-control" step="any" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="LocationPoint.OpeningHours" class="form-label">Giờ mở cửa</label>
                <input asp-for="LocationPoint.OpeningHours" class="form-control" placeholder="08:00 - 22:00" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="LocationPoint.PriceRange" class="form-label">Khoảng giá</label>
                <input asp-for="LocationPoint.PriceRange" class="form-control" placeholder="50.000 - 200.000 VNĐ" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Hình ảnh</label>
                <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                <small class="text-muted">Chọn file ảnh đại diện</small>
            </div>
        </div>

        <hr />
        <div class="d-flex justify-content-end gap-3">
            <a href="/Owner/Dashboard" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-gradient">
                <i class="fas fa-paper-plane me-2"></i>Gửi đăng ký
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('geocodeBtn')?.addEventListener('click', async function() {
            const address = document.getElementById('addressInput').value;
            if (!address) {
                alert('Vui lòng nhập địa chỉ');
                return;
            }

            this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lấy...';
            this.disabled = true;

            try {
                const response = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(address)}&format=json&limit=1`);
                const data = await response.json();

                if (data && data.length > 0) {
                    document.querySelector('#LocationPoint_Latitude').value = parseFloat(data[0].lat);
                    document.querySelector('#LocationPoint_Longitude').value = parseFloat(data[0].lon);
                    alert('✅ Đã lấy tọa độ thành công!');
                } else {
                    alert('❌ Không tìm thấy tọa độ');
                }
            } catch (error) {
                alert('❌ Lỗi khi lấy tọa độ');
            } finally {
                this.innerHTML = '<i class="fas fa-map-pin"></i> Lấy tọa độ';
                this.disabled = false;
            }
        });
    </script>
}