@page
@model doanC_Admin.Pages.Owner.DashboardModel
@{
    Layout = "_OwnerLayout";
    ViewData["Title"] = "Dashboard | Chủ quán";
}

<style>
    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        transition: all 0.3s;
        border: 1px solid rgba(0,0,0,0.02);
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        margin-bottom: 1rem;
    }

        .stat-icon.orange-bg {
            background: #FFF3E0;
            color: #FF5722;
        }

    .stat-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.25rem;
    }

    .stat-label {
        font-size: 0.8rem;
        color: #7f8c8d;
        font-weight: 500;
    }

    .badge-approved {
        background: #28a745;
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
    }

    .badge-pending {
        background: #ffc107;
        color: #856404;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
    }

    .nav-tabs-custom {
        border-bottom: 2px solid #ecf0f1;
        margin-bottom: 1.5rem;
    }

        .nav-tabs-custom .nav-link {
            border: none;
            color: #7f8c8d;
            font-weight: 600;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s;
            cursor: pointer;
        }

            .nav-tabs-custom .nav-link:hover {
                color: #FF5722;
            }

            .nav-tabs-custom .nav-link.active {
                color: #FF5722;
                border-bottom: 2px solid #FF5722;
                background: transparent;
            }

    .chart-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        border: none;
        margin-bottom: 1.25rem;
        overflow: hidden;
    }

        .chart-card .card-header {
            background: white;
            border-bottom: 1px solid #ecf0f1;
            padding: 1rem 1.25rem;
            font-weight: 600;
            color: #2c3e50;
        }

            .chart-card .card-header i {
                color: #FF5722;
                margin-right: 0.5rem;
            }

        .chart-card .card-body {
            padding: 1.25rem;
        }

    .btn-gradient {
        background: linear-gradient(135deg, #FF5722, #E64A19);
        border: none;
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 10px;
        font-size: 0.8rem;
        transition: all 0.3s;
    }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,87,34,0.3);
            color: white;
        }

    .table {
        font-size: 0.85rem;
    }

        .table thead th {
            background: #f8f9fa;
            border-bottom: 2px solid #ecf0f1;
            font-weight: 600;
        }

    .welcome-card {
        background: linear-gradient(135deg, #FFF3E0, #FFE0CC);
        border-radius: 20px;
        padding: 1.25rem;
        margin-bottom: 1.5rem;
    }
</style>

<div class="container-fluid px-4">
    <!-- Welcome Card -->
    <div class="welcome-card">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="mb-1"><i class="fas fa-store me-2 text-primary"></i>Xin chào, @Model.OwnerName!</h4>
                <p class="mb-0 text-muted">Chào mừng bạn đến với hệ thống quản lý địa điểm FoodStreetGuide</p>
            </div>
            <div class="col-md-4 text-end">
                <span class="badge-approved me-2">
                    <i class="fas fa-check-circle me-1"></i>Đã duyệt: @Model.ApprovedCount
                </span>
                <span class="badge-pending">
                    <i class="fas fa-clock me-1"></i>Chờ duyệt: @Model.PendingCount
                </span>
            </div>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row">
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="stat-icon orange-bg">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <div class="stat-value">@Model.MyLocationsCount</div>
                <div class="stat-label">Địa điểm của bạn</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="stat-icon orange-bg">
                    <i class="fas fa-qrcode"></i>
                </div>
                <div class="stat-value">@Model.TotalScans.ToString("N0")</div>
                <div class="stat-label">Lượt quét QR</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="stat-icon orange-bg">
                    <i class="fas fa-headphones"></i>
                </div>
                <div class="stat-value">@Model.TotalListens.ToString("N0")</div>
                <div class="stat-label">Lượt nghe Audio</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="stat-icon orange-bg">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-value">0</div>
                <div class="stat-label">Lượt truy cập</div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs nav-tabs-custom" id="ownerTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="locations-tab" data-bs-toggle="tab" data-bs-target="#locations" type="button" role="tab">
                <i class="fas fa-map-marker-alt me-2"></i>Địa điểm
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="audio-tab" data-bs-toggle="tab" data-bs-target="#audio" type="button" role="tab">
                <i class="fas fa-headphones me-2"></i>Audio Guide
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="qr-tab" data-bs-toggle="tab" data-bs-target="#qr" type="button" role="tab">
                <i class="fas fa-qrcode me-2"></i>QR Code
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="reports-tab" data-bs-toggle="tab" data-bs-target="#reports" type="button" role="tab">
                <i class="fas fa-chart-bar me-2"></i>Báo cáo
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="ownerTabsContent">

        <!-- Tab 1: Địa điểm -->
        <div class="tab-pane fade show active" id="locations" role="tabpanel">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap">
                <div><i class="fas fa-store"></i> Quản lý địa điểm</div>
                <a href="/Owner/CreateLocation" class="btn btn-gradient btn-sm">
                    <i class="fas fa-plus me-1"></i>Thêm địa điểm
                </a>
            </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tên địa điểm</th>
                                    <th>Danh mục</th>
                                    <th>Trạng thái</th>
                                    <th>Lượt quét</th>
                                    <th>Lượt nghe</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.MyLocations != null && Model.MyLocations.Any())
                                {
                                    @foreach (var loc in Model.MyLocations)
                                    {
                                        <tr>
                                            <td>@loc.PointId</td>
                                            <td><strong>@loc.Name</strong></td>
                                            <td>@loc.Category</td>
                                            <td>
                                                @if (loc.IsApproved)
                                                {
                                                    <span class="badge-approved">
                                                        <i class="fas fa-check-circle me-1"></i>Đã duyệt
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge-pending">
                                                        <i class="fas fa-clock me-1"></i>Chờ duyệt
                                                    </span>
                                                }
                                            </td>
                                            <td>@loc.TotalScans.ToString("N0")</td>
                                            <td>@loc.TotalListens.ToString("N0")</td>
                                            <td>
                                                @if (loc.IsApproved)
                                                {
                                                    <a href="/Owner/EditLocation?id=@loc.PointId" class="btn btn-sm btn-warning me-1" title="Sửa">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                }
                                                <a href="/Owner/DeleteLocation?id=@loc.PointId" class="btn btn-sm btn-danger" title="Xóa"
                                                   onclick="return confirm('Bạn có chắc chắn muốn xóa địa điểm này?');">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">
                                            <i class="fas fa-store-slash fa-2x mb-2 d-block"></i>
                                            Bạn chưa có địa điểm nào. Hãy đăng ký địa điểm đầu tiên!
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 2: Audio Guide -->
        <div class="tab-pane fade" id="audio" role="tabpanel">
            <div class="chart-card">
                <div class="card-header">
                    <i class="fas fa-headphones"></i> Quản lý Audio
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Địa điểm</th>
                                    <th>File Audio</th>
                                    <th>Ngôn ngữ</th>
                                    <th>Nghe thử</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.MyAudios != null && Model.MyAudios.Any())
                                {
                                    @foreach (var audio in Model.MyAudios)
                                    {
                                        <tr>
                                            <td>@audio.AudioId</td>
                                            <td>@audio.LocationName</td>
                                            <td>@audio.FileName</td>
                                            <td>@audio.Language</td>
                                            <td>
                                                <audio controls style="height: 32px;">
                                                    <source src="@audio.FilePath" type="audio/mpeg">
                                                    Trình duyệt không hỗ trợ audio
                                                </audio>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            <i class="fas fa-headphones fa-2x mb-2 d-block"></i>
                                            Chưa có file audio nào
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 3: QR Code -->
        <div class="tab-pane fade" id="qr" role="tabpanel">
            <div class="chart-card">
                <div class="card-header">
                    <i class="fas fa-qrcode"></i> Quản lý QR Code
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Chỉ chọn được địa điểm đã được admin duyệt
                    </div>
                    <div class="row">
                        <div class="col-md-5">
                            <select id="qrLocationSelect" class="form-select mb-3">
                                <option value="">-- Chọn địa điểm --</option>
                                @if (Model.ApprovedLocations != null && Model.ApprovedLocations.Any())
                                {
                                    @foreach (var loc in Model.ApprovedLocations)
                                    {
                                        <option value="@loc.PointId">@loc.Name</option>
                                    }
                                }
                            </select>
                            <button class="btn btn-gradient w-100" id="generateQRBtn">
                                <i class="fas fa-qrcode me-2"></i>Tạo QR Code
                            </button>
                        </div>
                        <div class="col-md-7 text-center p-3 border rounded" id="qrPreview">
                            <i class="fas fa-qrcode fa-4x text-muted"></i>
                            <p class="text-muted mt-2">Chọn địa điểm và nhấn "Tạo QR Code"</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 4: Báo cáo -->
        <div class="tab-pane fade" id="reports" role="tabpanel">
            <div class="chart-card">
                <div class="card-header">
                    <i class="fas fa-chart-bar"></i> Thống kê
                </div>
                <div class="card-body">
                    <canvas id="statsChart" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Biểu đồ thống kê
        new Chart(document.getElementById('statsChart'), {
            type: 'bar',
            data: {
                labels: ['Lượt quét QR', 'Lượt nghe Audio'],
                datasets: [{
                    label: 'Số lượng',
                    data: [@Model.TotalScans, @Model.TotalListens],
                    backgroundColor: ['#FF5722', '#FF8A65'],
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'top' }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        title: { display: true, text: 'Số lượng' }
                    }
                }
            }
        });

        // Tạo QR Code
        document.getElementById('generateQRBtn')?.addEventListener('click', async function() {
            const locationId = document.getElementById('qrLocationSelect').value;
            if (!locationId) {
                alert('Vui lòng chọn địa điểm');
                return;
            }

            this.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang tạo...';
            this.disabled = true;

            try {
                const response = await fetch('/api/QrApi/GenerateQR', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        pointId: parseInt(locationId),
                        name: `QR_${locationId}_${Date.now()}`,
                        size: 200
                    })
                });
                const result = await response.json();

                if (result.success) {
                    document.getElementById('qrPreview').innerHTML = `
                        <img src="${result.qrImageData}" style="max-width:200px; border-radius:12px"/>
                        <div class="mt-2">
                            <button class="btn btn-sm btn-success" onclick="downloadQR('${result.qrImageData}', '${result.qrName}')">
                                <i class="fas fa-download me-1"></i>Tải xuống
                            </button>
                        </div>`;
                    alert('✅ Tạo QR Code thành công!');
                } else {
                    alert('❌ Lỗi: ' + result.message);
                }
            } catch (error) {
                alert('❌ Lỗi tạo QR Code');
            } finally {
                this.innerHTML = '<i class="fas fa-qrcode me-2"></i>Tạo QR Code';
                this.disabled = false;
            }
        });

        function downloadQR(imageData, fileName) {
            const link = document.createElement('a');
            link.download = `${fileName}.png`;
            link.href = imageData;
            link.click();
        }
    </script>
}