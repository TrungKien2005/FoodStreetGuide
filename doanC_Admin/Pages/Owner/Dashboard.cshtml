@page
@model doanC_Admin.Pages.Owner.DashboardModel
@{
    Layout = "_OwnerLayout";
    ViewData["Title"] = "Dashboard | Chủ quán";
}

<style>
    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        transition: all 0.3s;
        border: 1px solid rgba(0,0,0,0.02);
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        margin-bottom: 1rem;
    }

        .stat-icon.orange-bg {
            background: #FFF3E0;
            color: #FF5722;
        }

    .stat-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.25rem;
    }

    .stat-label {
        font-size: 0.8rem;
        color: #7f8c8d;
        font-weight: 500;
    }

    .badge-approved {
        background: #28a745;
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
    }

    .badge-pending {
        background: #ffc107;
        color: #856404;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
    }

    .nav-tabs-custom {
        border-bottom: 2px solid #ecf0f1;
        margin-bottom: 1.5rem;
    }

        .nav-tabs-custom .nav-link {
            border: none;
            color: #7f8c8d;
            font-weight: 600;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s;
            cursor: pointer;
        }

            .nav-tabs-custom .nav-link:hover {
                color: #FF5722;
            }

            .nav-tabs-custom .nav-link.active {
                color: #FF5722;
                border-bottom: 2px solid #FF5722;
                background: transparent;
            }

    .chart-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        border: none;
        margin-bottom: 1.25rem;
        overflow: hidden;
    }

        .chart-card .card-header {
            background: white;
            border-bottom: 1px solid #ecf0f1;
            padding: 1rem 1.25rem;
            font-weight: 600;
            color: #2c3e50;
        }

            .chart-card .card-header i {
                color: #FF5722;
                margin-right: 0.5rem;
            }

        .chart-card .card-body {
            padding: 1.25rem;
        }

    .btn-gradient {
        background: linear-gradient(135deg, #FF5722, #E64A19);
        border: none;
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 10px;
        font-size: 0.8rem;
        transition: all 0.3s;
    }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,87,34,0.3);
            color: white;
        }

    .table {
        font-size: 0.85rem;
    }

        .table thead th {
            background: #f8f9fa;
            border-bottom: 2px solid #ecf0f1;
            font-weight: 600;
        }

    .welcome-card {
        background: linear-gradient(135deg, #FFF3E0, #FFE0CC);
        border-radius: 20px;
        padding: 1.25rem;
        margin-bottom: 1.5rem;
    }
</style>

<div class="container-fluid px-4">
    <!-- Welcome Card -->
    <div class="welcome-card">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="mb-1"><i class="fas fa-store me-2 text-primary"></i>Xin chào, @Model.OwnerName!</h4>
                <p class="mb-0 text-muted">Chào mừng bạn đến với hệ thống quản lý địa điểm FoodStreetGuide</p>
            </div>
            <div class="col-md-4 text-end">
                <span class="badge-approved me-2">
                    <i class="fas fa-check-circle me-1"></i>Đã duyệt: @Model.ApprovedCount
                </span>
                <span class="badge-pending">
                    <i class="fas fa-clock me-1"></i>Chờ duyệt: @Model.PendingCount
                </span>
            </div>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row">
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="stat-icon orange-bg">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <div class="stat-value">@Model.MyLocationsCount</div>
                <div class="stat-label">Địa điểm của bạn</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="stat-icon orange-bg">
                    <i class="fas fa-qrcode"></i>
                </div>
                <div class="stat-value">@Model.TotalScans.ToString("N0")</div>
                <div class="stat-label">Lượt quét QR</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="stat-icon orange-bg">
                    <i class="fas fa-headphones"></i>
                </div>
                <div class="stat-value">@Model.TotalListens.ToString("N0")</div>
                <div class="stat-label">Lượt nghe Audio</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="stat-icon orange-bg">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-value">0</div>
                <div class="stat-label">Lượt truy cập</div>
            </div>
        </div>
    </div>

    <!-- Thống kê (Chuyển ra màn hình chính) -->
    <div class="row">
        <div class="col-12">
            <div class="chart-card mt-3">
                <div class="card-header">
                    <i class="fas fa-chart-bar"></i> Biểu đồ tổng quan
                </div>
                <div class="card-body">
                    <canvas id="statsChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Biểu đồ thống kê
        new Chart(document.getElementById('statsChart'), {
            type: 'bar',
            data: {
                labels: ['Lượt quét QR', 'Lượt nghe Audio'],
                datasets: [{
                    label: 'Số lượng',
                    data: [@Model.TotalScans, @Model.TotalListens],
                    backgroundColor: ['#FF5722', '#FF8A65'],
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'top' }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        title: { display: true, text: 'Số lượng' }
                    }
                }
            }
        });
    </script>
}