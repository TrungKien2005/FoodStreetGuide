@page
@model doanC_Admin.Pages.Owner.RegisterPoiModel
@{
    Layout = "_OwnerLayout";
    ViewData["Title"] = "Đăng ký địa điểm mới";
}

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
    .form-container {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        max-width: 900px;
        margin: 0 auto;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .required::after {
        content: "*";
        color: #dc3545;
        margin-left: 4px;
    }
    .btn-submit {
        background: linear-gradient(135deg, #FF5722, #E64A19);
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        width: 100%;
        border: none;
        transition: all 0.3s;
    }
    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255,87,34,0.3);
        color: white;
    }
    #mapPicker {
        height: 350px;
        border-radius: 12px;
        border: 1px solid #ced4da;
        margin-bottom: 15px;
        z-index: 1;
    }
</style>

<div class="container px-4 mb-5">
    <div class="form-container">
        <div class="text-center mb-4">
            <i class="fas fa-plus-circle fa-3x text-primary mb-2"></i>
            <h4>Đăng ký địa điểm mới</h4>
            <p class="text-muted">Điền thông tin địa điểm, admin sẽ duyệt trong thời gian sớm nhất</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model.ErrorMessage != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Location.Name" class="form-label required fw-bold">Tên địa điểm / Cửa hàng</label>
                    <input asp-for="Location.Name" class="form-control" required placeholder="Nhập tên địa điểm" />
                </div>
                
                <div class="col-md-6 mb-3">
                    <label asp-for="Location.Category" class="form-label required fw-bold">Danh mục</label>
                    <select asp-for="Location.Category" class="form-select" required>
                        <option value="">-- Chọn danh mục --</option>
                        <option value="Ăn vặt">🍢 Ăn vặt</option>
                        <option value="Đồ uống">☕ Đồ uống</option>
                        <option value="Đồ nướng">🔥 Đồ nướng</option>
                        <option value="Hải sản">🦐 Hải sản</option>
                        <option value="Nhà hàng">🍽️ Nhà hàng</option>
                        <option value="Quán ăn">🍜 Quán ăn</option>
                        <option value="Cafe">☕ Cafe</option>
                    </select>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label asp-for="Location.Phone" class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="Location.Phone" class="form-control" placeholder="Nhập số điện thoại liên hệ" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tải lên hình ảnh</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                </div>
                
                <div class="col-12 mb-3">
                    <label asp-for="Location.Address" class="form-label required fw-bold">Địa chỉ</label>
                    <div class="input-group">
                        <input asp-for="Location.Address" class="form-control" id="addressInput" required placeholder="Nhập địa chỉ chi tiết" />
                        <button type="button" id="geocodeBtn" class="btn btn-secondary">
                            <i class="fas fa-search-location"></i> Tìm tọa độ
                        </button>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Location.OpeningHours" class="form-label fw-bold">Giờ mở cửa</label>
                    <input asp-for="Location.OpeningHours" class="form-control" placeholder="VD: 09:00 - 22:00" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Location.PriceRange" class="form-label fw-bold">Khoảng giá</label>
                    <input asp-for="Location.PriceRange" class="form-control" placeholder="VD: 50.000 - 200.000 VNĐ" />
                </div>
                
                <div class="col-12 mb-3">
                    <label asp-for="Location.Description" class="form-label fw-bold">Mô tả chi tiết</label>
                    <textarea asp-for="Location.Description" class="form-control" rows="3" placeholder="Giới thiệu về địa điểm..."></textarea>
                </div>

                <!-- BẢN ĐỒ CHỌN TỌA ĐỘ -->
                <div class="col-12 mt-2 mb-3">
                    <label class="form-label fw-bold"><i class="fas fa-map-marked-alt text-primary me-2"></i>Chọn vị trí trên bản đồ</label>
                    <div id="mapPicker"></div>
                    <small class="text-muted"><i class="fas fa-info-circle me-1"></i>Nhấp vào bản đồ hoặc kéo biểu tượng để chọn tự động Vĩ độ / Kinh độ.</small>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Location.Latitude" class="form-label required fw-bold">Vĩ độ (Latitude)</label>
                    <input asp-for="Location.Latitude" id="latInput" class="form-control" step="any" required />
                </div>
                
                <div class="col-md-6 mb-4">
                    <label asp-for="Location.Longitude" class="form-label required fw-bold">Kinh độ (Longitude)</label>
                    <input asp-for="Location.Longitude" id="lngInput" class="form-control" step="any" required />
                </div>
            </div>

            <div class="alert alert-info">
                <i class="fas fa-shield-alt me-2"></i>
                Sau khi gửi đăng ký, địa điểm sẽ được chuyển đến Admin để xét duyệt. Bạn sẽ nhận được thông báo khi có kết quả.
            </div>

            <button type="submit" class="btn-submit">
                <i class="fas fa-paper-plane me-2"></i>Gửi đăng ký địa điểm
            </button>
        </form>
    </div>
</div>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Tọa độ mặc định (Hà Nội hoặc TP.HCM tùy bạn, ở đây lấy trung tâm TP.HCM)
            let defaultLat = 10.7769;
            let defaultLng = 106.7009;

            let latInput = document.getElementById('latInput');
            let lngInput = document.getElementById('lngInput');

            // Lấy tọa độ từ input nếu có
            let startLat = parseFloat(latInput.value) || defaultLat;
            let startLng = parseFloat(lngInput.value) || defaultLng;

            // Khởi tạo bản đồ
            let map = L.map('mapPicker').setView([startLat, startLng], 15);

            // Thêm layer bản đồ đường phố từ OpenStreetMap
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            // Tạo Marker có thể kéo thả
            let marker = L.marker([startLat, startLng], { draggable: true }).addTo(map);

            // Cập nhật input khi marker bị kéo thả
            marker.on('dragend', function (e) {
                let position = marker.getLatLng();
                updateInputs(position.lat, position.lng);
            });

            // Cập nhật marker và input khi click lên bản đồ
            map.on('click', function (e) {
                marker.setLatLng(e.latlng);
                updateInputs(e.latlng.lat, e.latlng.lng);
            });

            function updateInputs(lat, lng) {
                latInput.value = lat.toFixed(6);
                lngInput.value = lng.toFixed(6);
            }

            // Chức năng lấy tọa độ từ tên địa chỉ qua Nominatim
            document.getElementById('geocodeBtn').addEventListener('click', async function () {
                const address = document.getElementById('addressInput').value;
                if (!address) {
                    alert('Vui lòng nhập địa chỉ để tìm!');
                    return;
                }

                const btn = this;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang tìm...';
                btn.disabled = true;

                try {
                    const response = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(address)}&format=json&limit=1`);
                    const data = await response.json();

                    if (data && data.length > 0) {
                        const lat = parseFloat(data[0].lat);
                        const lon = parseFloat(data[0].lon);
                        
                        updateInputs(lat, lon);
                        marker.setLatLng([lat, lon]);
                        map.setView([lat, lon], 17); // Zoom sát vào địa điểm
                        
                        // Lấy chi tiết số điện thoại/tên từ địa điểm qua Nominatim là không khả thi vì Nominatim không mạnh về POI detail.
                        alert('✅ Đã lấy tọa độ thành công!');
                    } else {
                        alert('❌ Không tìm thấy tọa độ. Vui lòng nhập địa chỉ rõ ràng hơn (Thêm Phường, Quận, Thành Phố).');
                    }
                } catch (error) {
                    alert('❌ Lỗi khi gọi API tìm tọa độ.');
                } finally {
                    btn.innerHTML = '<i class="fas fa-search-location"></i> Tìm tọa độ';
                    btn.disabled = false;
                }
            });
        });
    </script>
}