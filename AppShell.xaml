<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="doanC_.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:doanC_"
    xmlns:views="clr-namespace:doanC_.Views"
    Title="doanC_"
    TabBarBackgroundColor="#2C1810"
    TabBarForegroundColor="#C8A882"
    TabBarUnselectedColor="#9E8B7E"
    TabBarTitleColor="#C8A882">

    <TabBar>
        <!-- Bản đồ -->
        <ShellContent
            Title="Bản đồ"
            Icon="map_icon.png"
            ContentTemplate="{DataTemplate views:MapPage}"
            Route="MapPage" />

        <!-- Điểm -->
        <ShellContent
            Title="Điểm"
            Icon="poi_icon.png"
            ContentTemplate="{DataTemplate views:PoiListPage}"
            Route="PoiListPage" />

        <!-- QR -->
        <ShellContent
            Title="QR"
            Icon="qr_icon.png"
            ContentTemplate="{DataTemplate views:QrScannerPage}"
            Route="QrScannerPage" />

        <!-- Cài đặt -->
        <ShellContent
            Title="Cài đặt"
            Icon="settings_icon.png"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
