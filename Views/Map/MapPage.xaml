<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="doanC_.Views.MapPage">

    <Grid RowDefinitions="*,Auto">

        <!-- BẢN ĐỒ -->
        <AbsoluteLayout Grid.Row="0">

            <!-- ✅ GOOGLE MAP -->
            <maps:Map x:Name="map"
                      IsShowingUser="True"
                      AbsoluteLayout.LayoutBounds="0,0,1,1"
                      AbsoluteLayout.LayoutFlags="All"/>

            <!-- Thanh tìm kiếm -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    Padding="10"
                    Margin="20,20,20,0"
                    AbsoluteLayout.LayoutBounds="0.5,0.08,0.9,60"
                    AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional">

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <Label Text="🔍"
                           FontSize="18"
                           VerticalOptions="Center"/>

                    <Entry Placeholder="Tìm điểm thuyết minh..."
                           Grid.Column="1"
                           FontSize="14"
                           VerticalOptions="Center"
                           Margin="10,0,0,0"/>

                    <Border Grid.Column="2"
                            BackgroundColor="#EEE"
                            StrokeShape="RoundRectangle 15"
                            Padding="10,5">

                        <Label Text="VI"
                               FontSize="10"
                               VerticalOptions="Center"/>

                    </Border>

                </Grid>

            </Border>

            <!-- Nút GPS -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 30"
                    HeightRequest="45"
                    WidthRequest="45"
                    AbsoluteLayout.LayoutBounds="0.95,0.85,45,45"
                    AbsoluteLayout.LayoutFlags="PositionProportional">

                <Label Text="📍"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="20"/>

            </Border>

        </AbsoluteLayout>

        <!-- THẺ THÔNG TIN -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                Padding="20">

            <VerticalStackLayout Spacing="10">

                <Label Text="📍 Đang gần · 45m"
                       TextColor="Red"
                       FontSize="12"/>

                <Label Text="Bánh Mì Huỳnh Hoa"
                       FontSize="18"
                       FontAttributes="Bold"/>

                <Label Text="🔊 Nhấn để nghe thuyết minh"
                       FontSize="13"
                       TextColor="Gray"/>

                <Button Text="▶ Phát thuyết minh"
                        BackgroundColor="#E85C2B"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="45"/>

            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentPage>